# Database connection used by backend
DATABASE_URL=postgresql+psycopg2://zakupai:zakupai@db:5432/zakupai

# Postgres container credentials (docker-compose)
POSTGRES_USER=zakupai
POSTGRES_PASSWORD=zakupai
POSTGRES_DB=zakupai

# Allowed origins for FastAPI CORS (comma separated)
CORS_ORIGINS=http://localhost,http://localhost:4173,http://localhost:3000

# JWT secret for authentication (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
JWT_SECRET_KEY=replace_me_with_random_secret

# ============================================================================
# LLM transport (used by every chat-completion call across M1..M4)
# ============================================================================
#
# The whole backend talks to LLMs through one OpenAI-compatible client
# (app/services/llm.py). Set the three core variables below and you're
# done — every model is reachable through OpenRouter, no vendor SDKs.
#
# Power users can override the model on a per-task basis by setting
# LLM_MODEL_<TASK_UPPER>, e.g.
#   LLM_MODEL_COMPARE_CHARACTERISTICS=anthropic/claude-3.5-sonnet
#   LLM_MODEL_LOTS_EXTRACTION=openai/gpt-4o
# Same goes for LLM_BASE_URL_<TASK> and LLM_API_KEY_<TASK> — useful when
# you want one task to bypass OpenRouter and hit a provider directly.
#
# Known task names (grep for them in app/services/llm_tasks.py):
#   search_queries, lots_extraction, bid_lots_extraction,
#   perplexity_postprocess, kp_items_extraction,
#   compare_characteristics, supplier_search_perplexity
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=replace_me
LLM_MODEL=google/gemini-2.0-flash-001

# Optional: pin specific models per task. Examples (commented out).
# LLM_MODEL_COMPARE_CHARACTERISTICS=anthropic/claude-3.5-sonnet
# LLM_MODEL_LOTS_EXTRACTION=openai/gpt-4o
# LLM_MODEL_KP_ITEMS_EXTRACTION=qwen/qwen-2.5-72b-instruct

# ----------------------------------------------------------------------------
# Backward-compat env vars. The unified client still reads these as a fallback
# if the LLM_* names above are not set. Existing prod .env files keep working
# without changes.
# ----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=
# These two are still consumed directly by etl/worker.py and have no LLM_*
# equivalent yet (embeddings + matcher are out of scope of the unified client).
OPENROUTER_EMBEDDING_MODEL=perplexity/pplx-embed-v1-4b
OPENROUTER_MATCH_MODEL=openai/gpt-4o-mini

# ----------------------------------------------------------------------------
# Supplier search & ETL
# ----------------------------------------------------------------------------
YANDEX_API_KEY=replace_me
YANDEX_FOLDER_ID=replace_me
LOT_MATCH_MIN_CONFIDENCE=0.45
PERPLEXITY_MODEL=perplexity/sonar-pro-search
PERPLEXITY_MIN_CONTACTS=10
PAGE_LOAD_TIMEOUT=25
QUERY_DOCS_LIMIT=3
ETL_POLL_INTERVAL=5
ENABLE_EMBEDDED_QUEUE=false

# GISP scraper microservice (M4 Нацрежим)
# In docker-compose deploys leave this as the default — the backend resolves
# 'gisp-scraper' through the docker network. For local development point it
# at a host port (e.g. http://localhost:8001).
GISP_SCRAPER_URL=http://gisp-scraper:8000
GISP_MAX_CONCURRENT=3
PP719_HTTP_TIMEOUT=30
CATALOG_PAGE_TIMEOUT=30
